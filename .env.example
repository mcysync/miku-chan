# --- API Keys (keep these secret) ---
# Primary: works with lovable gateway (backward compat)
LOVABLE_API_KEY=your_lovable_api_key_here

# Alternative generic names - you can use either one:
# AI_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

# Optional: Override gateway URL (default is lovable gateway)
# AI_GATEWAY_URL=https://ai.gateway.lovable.dev/v1
# AI_GATEWAY_URL=https://api.openai.com/v1
# AI_GATEWAY_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Optional: Override model (default: google/gemini-2.5-pro)
# AI_MODEL=google/gemini-2.5-pro
# AI_MODEL=google/gemini-2.5-flash
# AI_MODEL=openai/gpt-4o
